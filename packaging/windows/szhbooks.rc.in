#include <windows.h>

#define SZHBOOKS_VERSION_COMMA @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
#define SZHBOOKS_VERSION_STRING "@PROJECT_VERSION@.0\0"

IDI_ICON1 ICON "@SZHBOOKS_WINDOWS_ICON@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION SZHBOOKS_VERSION_COMMA
 PRODUCTVERSION SZHBOOKS_VERSION_COMMA
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "SZHerio\0"
            VALUE "FileDescription", "SZHBooks local-first desktop reader\0"
            VALUE "FileVersion", SZHBOOKS_VERSION_STRING
            VALUE "InternalName", "SZHBooks\0"
            VALUE "LegalCopyright", "Copyright (c) 2026 SZHerio\0"
            VALUE "OriginalFilename", "SZHBooks.exe\0"
            VALUE "ProductName", "SZHBooks\0"
            VALUE "ProductVersion", SZHBOOKS_VERSION_STRING
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
